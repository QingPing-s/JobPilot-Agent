OPENAI_API_KEY=your_deepseek_api_key
OPENAI_BASE_URL=https://api.deepseek.com
MODEL_NAME=deepseek-chat
LLM_TIMEOUT_SECONDS=60
LLM_SDK_MAX_RETRIES=1
LLM_INPUT_COST_PER_MILLION=0
LLM_OUTPUT_COST_PER_MILLION=0

JOBPILOT_AUTH_ENABLED=false
JOBPILOT_JWT_SECRET=replace_with_a_long_random_secret
JOBPILOT_JWT_TTL_SECONDS=3600
JOBPILOT_USER_USERNAME=jobpilot-user
JOBPILOT_USER_PASSWORD=replace_me
JOBPILOT_ADMIN_USERNAME=jobpilot-admin
JOBPILOT_ADMIN_PASSWORD=replace_me
JOBPILOT_RUNS_PER_MINUTE=10
JOBPILOT_WORKER_THREADS=2
JOBPILOT_EMBEDDING_BACKEND=chroma
