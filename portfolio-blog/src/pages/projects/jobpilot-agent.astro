---
import BaseLayout from "../../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="JobPilot RAG-Agent | Project Case"
  description="JobPilot RAG-Agent project case study."
>
  <article class="article-page">
    <header class="article-header">
      <p class="eyebrow">Project Case</p>
      <h1>JobPilot RAG-Agent</h1>
      <p class="tagline">LangGraph + FastAPI + React + ChromaDB + DeepSeek API</p>
      <p>
        一个面向 AI Agent / RAG / LLM 应用实习岗位申请的岗位匹配与简历优化 Agent，重点展示完整工程链路，而不是单次 Prompt Demo。
      </p>
    </header>

    <img class="wide-image" src={`${base}jobpilot-workbench.png`} alt="JobPilot Agent 工作台界面截图" />

    <section class="content-grid">
      <div>
        <h2>项目目标</h2>
        <p>
          将候选人画像、岗位 JD、岗位库检索、匹配评分、差距分析、简历建议和运行日志串成一个可交互系统，用于辅助实习岗位筛选和求职材料优化。
        </p>
      </div>
      <div>
        <h2>技术栈</h2>
        <ul>
          <li>Backend: Python, FastAPI, LangGraph, Pydantic</li>
          <li>LLM: DeepSeek API via OpenAI SDK</li>
          <li>Retrieval: ChromaDB, TF-IDF hybrid retrieval</li>
          <li>Frontend: React, Vite</li>
          <li>Quality: pytest, offline evaluation, trace logging</li>
        </ul>
      </div>
    </section>

    <section class="section compact">
      <h2>核心能力</h2>
      <div class="metric-grid">
        <div><strong>01</strong><span>Candidate Profile Extraction</span></div>
        <div><strong>02</strong><span>JD Parsing and Job Library</span></div>
        <div><strong>03</strong><span>Hybrid Retrieval and Rerank</span></div>
        <div><strong>04</strong><span>Requirement-based Match Scoring</span></div>
        <div><strong>05</strong><span>Gap Analysis and Resume Suggestions</span></div>
        <div><strong>06</strong><span>Trace Logging and Offline Eval</span></div>
      </div>
    </section>

    <section class="section compact">
      <h2>简历表述</h2>
      <p class="quote-block">
        构建 JobPilot RAG-Agent 实习岗位匹配系统，使用 LangGraph 编排候选人画像抽取、JD 解析、混合检索、岗位重排序、规则评分、差距分析和简历建议生成流程；结合 Pydantic 约束结构化输出，SQLite 持久化岗位库，Trace Logger 记录节点执行过程，并通过离线评测统计 Recall@K、Precision@K、Hit@K 等指标。
      </p>
    </section>
  </article>
</BaseLayout>
