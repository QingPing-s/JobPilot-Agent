---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const heroImage = `${base}jobpilot-workbench.png`;
---

<BaseLayout
  title="JY | AI Agent Portfolio Blog"
  description="AI Agent, RAG, and LLM application portfolio for internship applications."
>
  <section class="hero" style={`--hero-image: url('${heroImage}')`}>
    <div class="hero-content">
      <p class="eyebrow">AI Agent / RAG / LLM Application</p>
      <h1>JY 的 AI Agent 工程作品集</h1>
      <p class="hero-copy">
        聚焦 LangGraph、RAG、DeepSeek API、结构化输出、检索评测和前后端交互，把实习项目做成可展示、可运行、可复盘的工程案例。
      </p>
      <div class="hero-actions">
        <a class="primary-link" href={`${base}projects/jobpilot-agent/`}>查看核心项目</a>
        <a class="secondary-link" href={`${base}blog/`}>阅读技术博客</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="eyebrow">Featured Project</p>
      <h2>核心项目</h2>
    </div>
    <article class="feature-card">
      <img src={heroImage} alt="JobPilot Agent 工作台界面截图" loading="lazy" />
      <div>
        <p class="tagline">LangGraph + FastAPI + React + ChromaDB</p>
        <h3>JobPilot RAG-Agent</h3>
        <p>
          面向 AI Agent / RAG / LLM 应用实习岗位申请的岗位匹配与简历优化系统，支持岗位库、混合检索、重排序、规则评分、Trace 日志和离线评测。
        </p>
        <div class="chips">
          <span>Hybrid Retrieval</span>
          <span>Rule-based Scoring</span>
          <span>Trace Logging</span>
          <span>Offline Eval</span>
        </div>
        <a class="text-link" href={`${base}projects/jobpilot-agent/`}>进入项目案例</a>
      </div>
    </article>
  </section>

  <section class="section split">
    <div>
      <p class="eyebrow">Writing</p>
      <h2>技术文章方向</h2>
      <p>
        博客会围绕项目本身沉淀工程复盘，例如岗位 JD 结构化、混合召回、评分体系设计、Agent Trace 和离线评测。
      </p>
    </div>
    <div class="list-panel">
      <a href={`${base}blog/jobpilot-agent-engineering-notes/`}>如何把 LLM Demo 做成可写进简历的 Agent 项目</a>
      <a href={`${base}projects/jobpilot-agent/`}>JobPilot-Agent 项目架构拆解</a>
      <a href={`${base}resume/`}>简历展示页面</a>
    </div>
  </section>
</BaseLayout>
