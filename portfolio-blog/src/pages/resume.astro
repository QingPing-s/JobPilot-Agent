---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="简历 | JY Portfolio">
  <section class="article-page resume-page">
    <header class="article-header">
      <p class="eyebrow">Resume</p>
      <h1>JY</h1>
      <p>AI Agent / RAG / LLM Application Intern Candidate</p>
    </header>

    <section class="resume-section">
      <h2>项目经历</h2>
      <div class="timeline-item">
        <h3>JobPilot RAG-Agent</h3>
        <p>
          基于 LangGraph + DeepSeek API + ChromaDB + FastAPI + React 构建实习岗位匹配与简历优化 Agent，覆盖画像抽取、JD 解析、混合召回、重排序、规则评分、差距分析、Trace 和离线评测。
        </p>
      </div>
    </section>

    <section class="resume-section">
      <h2>技能关键词</h2>
      <div class="chips">
        <span>Python</span>
        <span>FastAPI</span>
        <span>LangGraph</span>
        <span>RAG</span>
        <span>DeepSeek API</span>
        <span>Pydantic</span>
        <span>ChromaDB</span>
        <span>React</span>
      </div>
    </section>
  </section>
</BaseLayout>
